# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is git-ignored - NEVER commit real secrets or API keys.

# --- Postgres ---
POSTGRES_USER=siege_admin
POSTGRES_PASSWORD=changeme_use_a_real_password
POSTGRES_DB=siege
POSTGRES_PORT=5432

# --- Backend ---
PORT=3000
# Host "db" matches the docker-compose service name below, not "localhost".
DATABASE_URL=postgres://siege_admin:changeme_use_a_real_password@db:5432/siege
JWT_SECRET=changeme_generate_a_long_random_string
GEMINI_API_KEY=your_gemini_api_key_here

# --- Nginx ---
NGINX_PORT=8080
